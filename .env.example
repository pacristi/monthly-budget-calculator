# Banco a scrapear. Default "bchile". Otros soportados por open-banking-chile:
# banco_estado, santander, bci, ... (ver https://www.npmjs.com/package/open-banking-chile)
BANCO_ID=bchile

# Credenciales para login en la web del banco. Se usan SOLO localmente para
# el scraper de Node. Nunca salen de tu máquina.
BANCO_RUT=12.345.678-9
BANCO_PASS=tu_clave_internet
